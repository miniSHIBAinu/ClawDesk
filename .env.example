# ============================================
# ClawDesk - Environment Configuration Template
# Copy this file: cp .env.example .env.dev
# Fill in your actual credentials below
# ============================================

# --- Supabase Configuration (BẮT BUỘC) ---
# Lấy tại: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_ACCESS_TOKEN=your-access-token-here
SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
SUPABASE_SECRET_KEY=your-secret-key-here

# --- Server Configuration ---
PORT=8080

# --- Vercel Deployment ---
# Lấy tại: vercel.com → Settings → Tokens
VERCEL_TOKEN=your-vercel-token-here

# --- GitHub ---
# Lấy tại: github.com → Settings → Developer Settings → Personal access tokens
GITHUB_TOKEN=your-github-token-here

# --- LLM API Keys (tuỳ chọn, override per-agent) ---
# Ít nhất 1 key bên dưới để AI Agent hoạt động
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
